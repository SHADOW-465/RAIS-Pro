# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (.env.example is intentionally tracked)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# supabase
supabase/.temp/

# assistant
.claude/

# git worktrees
.worktrees/

# brainstorm visuals
.superpowers/

# design handoff bundle (regenerated on demand)
.design-fetch/

# user data — real factory spreadsheets stay local, never committed
DATA/
*.xlsx
*.xls
*.csv
~$*

# graphify — only the human-readable GRAPH_REPORT.md is committed.
# Everything else (graph.json, graph.html, cache, converted source docs,
# manifest with absolute paths) is regenerated locally via `graphify update .`.
.graphify_python
.graphify_uncached.txt
graphify-out/cache/
graphify-out/converted/
graphify-out/graph.html
graphify-out/graph.json
graphify-out/manifest.json
graphify-out/cost.json
graphify-out/.graphify_root
graphify-out/.graphify_*.json
graphify-out/.graphify_chunk_*.json

# Playwright MCP diagnostic captures + ad-hoc screenshots
.playwright-mcp/
rais-*-output.png
rais-*-FIXED.png

# diagnostic screenshots from UI verification
audit-*.png
