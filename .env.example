# ── Canonical ledger persistence (Supabase / Postgres) ──────────────────────
# The canonical event ledger uses Supabase automatically when a URL + a key are
# set. Apply supabase/migrations/20260618_canonical_ledger.sql first so the
# tables exist. Server-side writes need the service-role key (the anon key hits
# RLS and will fail writes). Force the in-RAM store instead (throwaway dev /
# tests): set MOID_STORE=memory.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# MOID_STORE=memory

# ── AI backend ──────────────────────────────────────────────────────────────
# The app tries each backend that has credentials configured, in priority
# order, until one succeeds. Configure as many as you want — failures
# (rate limits, out-of-credit, transient 5xx) cascade automatically.
#
# Priority order:
#   1. Vercel AI Gateway   AI_GATEWAY_API_KEY  (or OIDC on Vercel)
#   2. Anthropic direct    ANTHROPIC_API_KEY
#   3. OpenRouter          OPENROUTER_API_KEY
#   4. Google Gemini       GOOGLE_GENERATIVE_AI_API_KEY
#   5. Groq                GROQ_API_KEY
#   6. Ollama (local)      OLLAMA_BASE_URL
#
# To force a single backend (skip the chain), set RAIS_AI_BACKEND to one of:
# gateway | anthropic | openrouter | google | groq | ollama.

# RAIS_AI_BACKEND=groq

# 1. Vercel AI Gateway (recommended for production)
#    Get a key from https://vercel.com/<team>/ai-gateway. On Vercel,
#    deployments authenticate via OIDC automatically — no key needed there.
#    Default models: anthropic/claude-sonnet-4.6 + anthropic/claude-haiku-4.5.
# AI_GATEWAY_API_KEY=your-gateway-key

# 2. Direct Anthropic
#    Default models: claude-sonnet-4-6 + claude-haiku-4-5.
# ANTHROPIC_API_KEY=your-anthropic-key

# 3. OpenRouter (multiplexer over 100+ models; has free endpoints)
#    Get a key from https://openrouter.ai/keys.
#    Defaults: nvidia/nemotron-3-super-120b-a12b:free + minimax/minimax-m2.5:free.
#    NOTE: free-tier OpenRouter models share a global rate-limit pool; if it
#    fails, the chain falls through to Google/Groq. Add OpenRouter credits or
#    point at a paid model via OPENROUTER_MODEL for production reliability.
#    Override via OPENROUTER_MODEL / OPENROUTER_MODEL_FAST to use paid models.
# OPENROUTER_API_KEY=your-openrouter-key
# OPENROUTER_MODEL=anthropic/claude-sonnet-4.6
# OPENROUTER_MODEL_FAST=anthropic/claude-haiku-4.5

# 4. Google Gemini (free tier available)
#    Get a key from https://aistudio.google.com/app/apikey.
#    Default models: gemini-2.5-flash + gemini-2.5-flash-lite.
# GOOGLE_GENERATIVE_AI_API_KEY=your-google-key

# 5. Groq (fast, generous free tier)
#    Get a key from https://console.groq.com/keys.
#    Default model: llama-3.3-70b-versatile.
# GROQ_API_KEY=your-groq-key

# 6. Local Ollama (offline)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b           # CPU-friendly default
# OLLAMA_MODEL_FAST=qwen2.5:3b      # used for manifest classification (Phase 1)
#
# GPU upgrade (better accuracy, ~10 GB VRAM):
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_MODEL_FAST=qwen2.5:3b
