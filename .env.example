NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# ── AI backend ──────────────────────────────────────────────────────────────
# Priority order (first match wins): AI Gateway → direct Anthropic → Ollama.
# Set ONE of the groups below.

# 1. Vercel AI Gateway (recommended)
#    Get a key from https://vercel.com/<team>/ai-gateway. On Vercel,
#    deployments authenticate via OIDC automatically — no key needed there.
#    Default models: anthropic/claude-sonnet-4.6 (main) + anthropic/claude-haiku-4.5 (manifest).
# AI_GATEWAY_API_KEY=your-gateway-key

# 2. Direct Anthropic (local dev fallback)
#    Default models: claude-sonnet-4-6 + claude-haiku-4-5.
# ANTHROPIC_API_KEY=your-anthropic-key

# 3. Local Ollama (offline dev)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=qwen2.5:3b           # CPU-friendly default
# OLLAMA_MODEL_FAST=qwen2.5:3b      # used for the manifest classification phase
#
# GPU upgrade (better accuracy, ~10 GB VRAM):
# OLLAMA_MODEL=qwen2.5:14b
# OLLAMA_MODEL_FAST=qwen2.5:3b
