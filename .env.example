# ── Canonical ledger persistence (Supabase / Postgres) ──────────────────────
# The canonical event ledger uses Supabase automatically when a URL + a key are
# set. Apply supabase/migrations/20260618_canonical_ledger.sql first so the
# tables exist. Server-side writes need the service-role key (the anon key hits
# RLS and will fail writes). Force the in-RAM store instead (throwaway dev /
# tests): set MOID_STORE=memory.
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# MOID_STORE=memory

# ── AI backend ──────────────────────────────────────────────────────────────
# The app tries each configured backend in priority order until one succeeds.
# Failures (rate limits, unreachable server, transient 5xx) cascade automatically.
#
# Priority order:
#   1. MiniCPM (self-hosted, primary)  MINICPM_BASE_URL
#   2. Groq    (API fallback)          GROQ_API_KEY
#
# To force a single backend (skip the chain), set RAIS_AI_BACKEND to
# minicpm | groq.

# RAIS_AI_BACKEND=minicpm

# 1. MiniCPM — self-hosted on our servers behind an OpenAI-compatible endpoint
#    (vLLM / llama.cpp / SGLang). https://huggingface.co/openbmb/MiniCPM5-1B
#    Only MINICPM_BASE_URL is required; MINICPM_API_KEY is optional (local
#    servers usually accept any bearer token). Override the served model id
#    via MINICPM_MODEL if it differs from the default.
# MINICPM_BASE_URL=http://localhost:8000/v1
# MINICPM_API_KEY=local
# MINICPM_MODEL=openbmb/MiniCPM5-1B
# MINICPM_MODEL_FAST=openbmb/MiniCPM5-1B

# 2. Groq (fast, generous free-tier API fallback)
#    Get a key from https://console.groq.com/keys.
#    Default models: llama-3.3-70b-versatile + llama-3.1-8b-instant.
# GROQ_API_KEY=your-groq-key
# GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_MODEL_FAST=llama-3.1-8b-instant
