# ────────────────────────────────────────────────────────────────────────────
# RAIS / MO!D on-prem appliance configuration.
# Copy to `.env` and fill in. NEVER commit the filled-in .env.
#   cp .env.template .env
# ────────────────────────────────────────────────────────────────────────────

# --- Appliance identity -------------------------------------------------------
# Hostname the operators browse to. Works even without DNS (Caddy also serves on
# the box's IP). If you set a name, add it to the operators' hosts file or DNS.
APP_DOMAIN=rais.local
APP_VERSION=latest

# --- Database (Postgres container) -------------------------------------------
# The DB runs inside compose as service "db". These create it on first boot.
POSTGRES_USER=rais
POSTGRES_PASSWORD=change-me-to-a-long-random-string
POSTGRES_DB=rais
# Connection string the app uses (host "db" is the compose service name).
DATABASE_URL=postgres://rais:change-me-to-a-long-random-string@db:5432/rais

# Storage backend for the canonical event ledger.
#   postgres = persist to the Postgres container (production)
#   memory   = throwaway in-RAM (tests / first-boot smoke only)
MOID_STORE=postgres

# --- Local LLM (Ollama container, zero egress) -------------------------------
RAIS_AI_BACKEND=ollama
OLLAMA_BASE_URL=http://ollama:11434
# CPU-friendly default. After first boot, pull it:  docker compose exec ollama ollama pull qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b
OLLAMA_MODEL_FAST=qwen2.5:3b
# GPU upgrade (better accuracy, ~10 GB VRAM): set OLLAMA_MODEL=qwen2.5:14b and
# enable the GPU block in docker-compose.yml.

# --- Egress guard -------------------------------------------------------------
# Hard-off by default: no cloud AI provider, no outbound calls. Leave these
# UNSET for a fully air-gapped appliance. (Only set a cloud key if the customer
# grants a firewall exception AND the scrubber/egress-log are enabled.)
# AI_GATEWAY_API_KEY=
# ANTHROPIC_API_KEY=
# GROQ_API_KEY=

NEXT_TELEMETRY_DISABLED=1

# --- Licensing (optional, Stage B / Tier-2 hardening) ------------------------
# Signed, node-locked license file gate. Leave blank until implemented.
# RAIS_LICENSE_KEY=
